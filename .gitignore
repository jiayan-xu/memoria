# Rust
target/

# Python (for optional PyO3 builds)
__pycache__/
*.pyc
*.egg-info/
*.pyd
*.so

# Runtime data
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Auto-generated admin key (P0-2: never commit)
admin_key.secret

# Local secrets (P0: never commit real .env)
.env
*.env.local
*.env.*.local
# but keep the documented example
!.env.example

# Single-writer lock file (P0-4)
*.pid

# Logs
*.log

# OS
Thumbs.db
.DS_Store

# IDE
.vscode/
.idea/
*.swp
