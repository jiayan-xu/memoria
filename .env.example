# Memoria 环境变量样例（P2-6 DX）
#
# 用法：复制为 `.env` 后填写真实值。`.env` 已被 .gitignore 忽略，永不提交。
# Usage: copy to `.env` and fill in. `.env` is git-ignored; never commit secrets.
#
# 所有值在此均为占位符 <...> 或安全默认值；不存在真实密钥。

# ---- 核心 Core ----
# 主数据库路径（容器内默认 /app/data/memoria.db）
MEMORIA_DB_PATH=data/memoria.db
# 绑定地址：默认 127.0.0.1（仅本机）。置 0.0.0.0 会暴露到局域网，需自担风险。
MEMORIA_HOST=127.0.0.1
# 服务端口
MEMORIA_PORT=9003
# 管理员密钥：不填则启动时自动生成并打印到日志。生产环境务必显式设置。
# Generate a strong value, e.g. `openssl rand -hex 32`. Never reuse the placeholder.
MEMORIA_ADMIN_KEY=<YOUR_ADMIN_KEY>
# 审计库路径（默认 <data 父目录>/audit.db）
MEMORIA_AUTH_DB_PATH=data/audit.db

# ---- 备份（GFS 轮转，P0）----
MEMORIA_BACKUP_DIR=data/backups
MEMORIA_BACKUP_INTERVAL_HOURS=24

# ---- 运行时线程 ----
MEMORIA_WORKER_THREADS=4
MEMORIA_MAX_BLOCKING_THREADS=512

# ---- 近义去重（P1-3）----
MEMORIA_NEAR_DUP_ENABLED=true
MEMORIA_NEAR_DUP_THRESHOLD=0.92
MEMORIA_NEAR_DUP_TOPK=5

# ---- 配额与滥用防护（P2-2，0 = 禁用该类别）----
# 每个命名空间每日写入条数上限
MEMORIA_QUOTA_WRITES_PER_DAY=1000
# 每个命名空间每分钟搜索次数上限
MEMORIA_QUOTA_SEARCHES_PER_MIN=120
# 每个命名空间每小时备份次数上限
MEMORIA_QUOTA_BACKUPS_PER_HOUR=10

# ---- Dream 巩固限流（P1-4，单位：秒）----
# 默认冷却（未指定具体 phase 时）
MEMORIA_DREAM_COOLDOWN_DEFAULT=300
# decay 阶段冷却（更激进）
MEMORIA_DREAM_COOLDOWN_DECAY=60

# ---- 可观测 / Tracing（P2-1）----
# 日志级别：trace | debug | info | warn | error
AGENT_CORE_LOG=info
RUST_LOG=info

# ---- Web / 桥接（可选 Optional）----
MEMORIA_WEB_DIR=web
# Capture Bridge 地址（如本地部署了 bridge 才需要）
# MEMORIA_BRIDGE_URL=http://127.0.0.1:9000

# ---- 语义检索嵌入服务（P3-0，可选 Optional）----
# 启用 HNSW 向量语义搜索：填入本地嵌入服务地址（见 embed_server.py）。
# 留空 = 禁用语义信号（仅 FTS5 + temporal + importance + category 融合）。
# 需另起 embed_server.py（系统 Python，已装 sentence_transformers）：
#   python embed_server.py   # 默认监听 127.0.0.1:8777/embed
# MEMORIA_EMBEDDING_URL=http://127.0.0.1:8777/embed

# ---- Agent-Core（jarvis 大脑）接线（可选 Optional）----
# jarvis 是 agent-core 在 memoria 侧的 admin 身份。agent-core 每次访问 memoria
# （/mcp、/api、dashboard 代理）都携带请求头：
#     X-Agent-Id: jarvis
#     X-Agent-Key: <本值>
# 重要：本变量由「客户端（agent-core）」读取并作为 X-Agent-Key 发送；
#       memoria 自身【不】读取它，而是校验 agent_registry 中 jarvis 行的
#       badge_token 是否等于本值（权限 admin、namespace *，可跨租户读全量记忆）。
# 因此 jarvis 智能体须预先注册一次（可由 dashboard 引导注册，或调用 MCP
# register_agent 工具：agent_id=jarvis, permission=admin, namespaces=["*"]）；
# 注册后本值须与库中 badge_token 完全一致。
# 留空：agent-core 退化为普通智能体（仅能访问自身命名空间，无法读全量记忆）。
# MEMORIA_JARVIS_BADGE=<YOUR_JARVIS_BADGE>
